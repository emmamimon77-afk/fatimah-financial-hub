<!DOCTYPE html>
<html>
<head>
    <title>Simple Video Chat</title>
    <style>
        body { margin: 0; padding: 20px; font-family: Arial; }
        #videos { display: flex; gap: 20px; margin-bottom: 20px; }
        video {
            width: 400px;
            height: 300px;
            background: #000;
            border: 2px solid #0066cc;
            display: block; /* Ensures video is visible */
            object-fit: cover; /* Fills the space without distortion */

        }
        .controls { margin: 20px 0; }
        button { padding: 10px 20px; margin: 5px; cursor: pointer; }
        #users { background: #f0f0f0; padding: 15px; border-radius: 5px; }
    </style>
</head>
<body>
    <!-- FATIMAH FINANCIAL HUB - GLOBAL NAVIGATION -->
    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-radius: 0 0 10px 10px;">
        <div style="display: flex; align-items: center; gap: 20px;">
            <a href="http://localhost:3000/" style="color: white; text-decoration: none; font-weight: bold; font-size: 1.2rem; padding: 5px 10px; border-radius: 5px; transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">
               <i class="fas fa-home" style="margin-right: 8px;"></i>Fatimah Hub
            </a>
            <a href="http://localhost:3000/finance-tools/" style="color: white; text-decoration: none; font-weight: 500; padding: 5px 10px; border-radius: 5px; transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">
               <i class="fas fa-calculator" style="margin-right: 5px;"></i> Tools
            </a>
            <a href="http://localhost:3000/telephony/" style="color: white; text-decoration: none; font-weight: 500; padding: 5px 10px; border-radius: 5px; transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='transparent'">
               <i class="fas fa-phone-alt" style="margin-right: 5px;"></i> Telephony
            </a>
        </div>
        <div style="color: white;">
            <span style="background: rgba(255,255,255,0.2); padding: 5px 15px; border-radius: 20px; font-weight: 500;">
                <i class="fas fa-user" style="margin-right: 5px;"></i> TELEPHONY
            </span>
        </div>
    </div>
    <!-- BREADCRUMB NAVIGATION -->
    <div style="max-width: 1200px; margin: 0 auto 20px auto; padding: 0 20px;">
        <a href="http://localhost:3000/" style="color: #667eea; text-decoration: none; font-weight: 500;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Home</a>
        <span style="margin: 0 8px; color: #999;">›</span>
        <a href="http://localhost:3000/finance-tools/" style="color: #667eea; text-decoration: none; font-weight: 500;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Tools</a>
        <span style="margin: 0 8px; color: #999;">›</span>
        <a href="../personal/" style="color: #667eea; text-decoration: none; font-weight: 500;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Telephony</a>
        <span style="margin: 0 8px; color: #999;">›</span>
        <span style="color: #333; font-weight: 500;">Simple Client</span>
    </div>
    <h1>Simple Video Chat</h1>
    
    <div id="videos">
        <div>
            <h3>You</h3>
            <video id="localVideo" autoplay muted playsinline></video>
        </div>
        <div>
            <h3>Remote</h3>
            <video id="remoteVideo" autoplay playsinline muted></video>
        </div>
    </div>
    
    <div class="controls">
        <button id="startBtn">Start Video</button>
        <button id="callBtn" disabled>Call User</button>
        <button id="hangupBtn" disabled>Hang Up</button>
        <button id="toggleVideo">Toggle Video</button>
        <button id="toggleAudio">Toggle Audio</button>
        <button id="testAudioBtn" style="background: #28a745; color: white;">
            🔊 Test Audio
        </button>
    </div>
    
    <div id="users">
        <h3>Online Users:</h3>
        <div id="userList">Loading...</div>
    </div>
    
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/simple-telephony.js"></script>

    <!-- 🔍 ADD THIS DEBUG SCRIPT HERE -->
    <script>
        // Debug helper to monitor peer connections
        function monitorPeerConnection(pc, label) {
            console.log(`🔍 Monitoring ${label} PeerConnection`);
            
            // Track ontrack events
            const originalOntrack = pc.ontrack;
            pc.ontrack = (e) => {
                console.log(`🎬 ${label} ONTRACK FIRED!`, {
                    streams: e.streams,
                    streamCount: e.streams.length,
                    track: e.track,
                    trackKind: e.track.kind,
                    trackId: e.track.id,
                    trackReadyState: e.track.readyState
                });
                
                // Check remote video element
                const remoteVideo = document.getElementById('remoteVideo');
                console.log(`📺 Remote video element check:`, {
                    exists: !!remoteVideo,
                    hasSrcObject: !!remoteVideo?.srcObject,
                    id: remoteVideo?.id
                });
                
                // Try to set the stream
                if (e.streams && e.streams[0]) {
                    console.log(`💿 Setting stream to remoteVideo`);
                    remoteVideo.srcObject = e.streams[0];
                    
                    // Try to play
                    remoteVideo.play()
                        .then(() => console.log(`✅ ${label} Remote video playing`))
                        .catch(err => console.log(`❌ ${label} Play error:`, err.message));
                }
                
                // Call original handler if it exists
                if (originalOntrack) {
                    originalOntrack(e);
                }
            };
            
            // Monitor connection states
            pc.onconnectionstatechange = () => {
                console.log(`${label} connection state:`, pc.connectionState);
            };
            
            pc.onsignalingstatechange = () => {
                console.log(`${label} signaling state:`, pc.signalingState);
            };
            
            pc.oniceconnectionstatechange = () => {
                console.log(`${label} ICE state:`, pc.iceConnectionState);
            };
            
            pc.onicecandidate = (e) => {
                if (e.candidate) {
                    console.log(`${label} ICE candidate:`, e.candidate.type);
                }
            };
        }
        
        // Make it globally accessible for manual debugging
        window.monitorPeerConnection = monitorPeerConnection;
        
        console.log('🔧 Debug script loaded. Use window.monitorPeerConnection(pc, "label") to monitor any PeerConnection');
    </script>
    <!-- END DEBUG SCRIPT -->
    <!-- FOOTER NAVIGATION -->
    <div style="margin-top: 60px; background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%); padding: 40px 20px; color: white; border-radius: 10px 10px 0 0;">
        <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 30px;">
        
            <div>
                <h4 style="color: #cbd5e0; margin-bottom: 15px; font-size: 1.1rem;">Fatimah Financial Hub</h4>
                <a href="http://localhost:3000/" style="color: #e2e8f0; display: block; margin-bottom: 8px; text-decoration: none; padding: 3px 0; transition: color 0.3s, padding-left 0.3s;" onmouseover="this.style.color='#667eea'; this.style.paddingLeft='5px'" onmouseout="this.style.color='#e2e8f0'; this.style.paddingLeft='0'">
                   <i class="fas fa-home" style="width: 20px; margin-right: 10px;"></i>Dashboard
                </a>
                <a href="http://localhost:3000/finance-tools/" style="color: #e2e8f0; display: block; margin-bottom: 8px; text-decoration: none; padding: 3px 0; transition: color 0.3s, padding-left 0.3s;" onmouseover="this.style.color='#667eea'; this.style.paddingLeft='5px'" onmouseout="this.style.color='#e2e8f0'; this.style.paddingLeft='0'">
                   <i class="fas fa-calculator" style="width: 20px; margin-right: 10px;"></i>All Tools
                </a> 
            </div>
        
            <div>
                <h4 style="color: #cbd5e0; margin-bottom: 15px; font-size: 1.1rem;">Calculators</h4>
                <a href="http://localhost:3000/finance-tools/islamic/" style="color: #e2e8f0; display: block; margin-bottom: 8px; text-decoration: none; padding: 3px 0; transition: color 0.3s, padding-left 0.3s;" onmouseover="this.style.color='#667eea'; this.style.paddingLeft='5px'" onmouseout="this.style.color='#e2e8f0'; this.style.paddingLeft='0'">
                   <i class="fas fa-islam" style="width: 20px; margin-right: 10px;"></i>Islamic Finance
                </a>
                <a href="http://localhost:3000/finance-tools/global/" style="color: #e2e8f0; display: block; margin-bottom: 8px; text-decoration: none; padding: 3px 0; transition: color 0.3s, padding-left 0.3s;" onmouseover="this.style.color='#667eea'; this.style.paddingLeft='5px'" onmouseout="this.style.color='#e2e8f0'; this.style.paddingLeft='0'">
                   <i class="fas fa-globe" style="width: 20px; margin-right: 10px;"></i>Global Tools
                </a>
                <a href="http://localhost:3000/finance-tools/personal/" style="color: #e2e8f0; display: block; margin-bottom: 8px; text-decoration: none; padding: 3px 0; transition: color 0.3s, padding-left 0.3s;" onmouseover="this.style.color='#667eea'; this.style.paddingLeft='5px'" onmouseout="this.style.color='#e2e8f0'; this.style.paddingLeft='0'">
                   <i class="fas fa-user" style="width: 20px; margin-right: 10px;"></i>Personal Finance
                </a>
            </div>
        
            <div>
                <h4 style="color: #cbd5e0; margin-bottom: 15px; font-size: 1.1rem;">Other Modules</h4>
                <a href="http://localhost:3000/telephony/" style="color: #e2e8f0; display: block; margin-bottom: 8px; text-decoration: none; padding: 3px 0; transition: color 0.3s, padding-left 0.3s;" onmouseover="this.style.color='#667eea'; this.style.paddingLeft='5px'" onmouseout="this.style.color='#e2e8f0'; this.style.paddingLeft='0'">
