<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Chat - Fatimah Hub</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            color: #1e293b;
        }

        .header {
            background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
            color: white;
            padding: 1rem 2rem;
        }
        .nav {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            font-size: 24px;
            font-weight: bold;
            text-decoration: none;
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo i {
            color: #fbbf24;
        }
        .nav-links {
            display: flex;
            gap: 30px;
            align-items: center;
        }
        .nav-links a {
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            font-weight: 500;
        }

        .breadcrumb {
            background: white;
            border-bottom: 1px solid #e2e8f0;
            padding: 1rem 2rem;
            font-size: 14px;
        }
        .breadcrumb a {
            color: #312e81;
            text-decoration: none;
        }

        .main-content {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 20px;
            display: grid;
            grid-template-columns: 300px 1fr 300px;
            gap: 20px;
        }

        /* Left Panel - Users */
        .users-panel {
            background: white;
            border-radius: 20px;
            padding: 20px;
            border: 1px solid #e2e8f0;
        }
        .panel-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .user-list {
            list-style: none;
        }
        .user-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            border-radius: 12px;
            margin: 5px 0;
            background: #f8fafc;
        }
        .user-avatar {
            width: 40px;
            height: 40px;
            background: #312e81;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }
        .user-info {
            flex: 1;
        }
        .user-name {
            font-weight: 600;
        }
        .user-status {
            font-size: 12px;
            color: #10b981;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            background: #10b981;
            border-radius: 50%;
            display: inline-block;
        }
        .call-btn {
            padding: 6px 12px;
            background: #10b981;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 12px;
        }

        /* Center Panel - Chat */
        .chat-panel {
            background: white;
            border-radius: 20px;
            padding: 20px;
            border: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            height: 600px;
        }
        .chat-header {
            padding-bottom: 15px;
            border-bottom: 1px solid #e2e8f0;
            margin-bottom: 15px;
        }
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .message {
            max-width: 70%;
            padding: 10px 15px;
            border-radius: 15px;
            word-wrap: break-word;
        }
        .message.self {
            align-self: flex-end;
            background: #312e81;
            color: white;
        }
        .message.other {
            align-self: flex-start;
            background: #f1f5f9;
        }
        .message.system {
            align-self: center;
            background: #fef3c7;
            color: #92400e;
            font-size: 12px;
        }
        .message-input-area {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #e2e8f0;
        }
        .message-input {
            flex: 1;
            padding: 12px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
        }
        .send-btn {
            padding: 12px 24px;
            background: #312e81;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
        }

        /* Right Panel - Settings */
        .settings-panel {
            background: white;
            border-radius: 20px;
            padding: 20px;
            border: 1px solid #e2e8f0;
        }
        .setting-group {
            margin: 15px 0;
        }
        .setting-label {
            font-weight: 500;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .join-section {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }
        .username-input {
            width: 100%;
            padding: 10px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            margin-bottom: 10px;
        }
        .join-btn {
            width: 100%;
            padding: 12px;
            background: #10b981;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

        .footer {
            background: white;
            border-top: 1px solid #e2e8f0;
            padding: 30px;
            text-align: center;
            color: #64748b;
            margin-top: 40px;
        }
        .arabic-footer {
            font-size: 24px;
            color: #312e81;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <header class="header">
        <nav class="nav">
            <a href="/" class="logo">
                <i class="fas fa-mosque"></i>
                Fatimah Hub
            </a>
            <div class="nav-links">
                <a href="/">Dashboard</a>
                <a href="/trading">Trading</a>
                <a href="/finance-tools">Tools</a>
                <a href="/telephony" style="color: #fbbf24;">Telephony</a>
                <a href="/economics">Economics</a>
                <a href="/resources">Resources</a>
            </div>
        </nav>
    </header>

    <div class="breadcrumb">
        <a href="/">Home</a> › <a href="/telephony">Telephony</a> › Simple Chat
    </div>

    <main class="main-content">
        <!-- Left Panel - Online Users -->
        <div class="users-panel">
            <div class="panel-title">
                <i class="fas fa-users"></i> Online Traders
                <span style="background: #e2e8f0; padding: 2px 8px; border-radius: 20px; font-size: 12px;" id="userCount">0</span>
            </div>
            <div class="user-list" id="userList">
                <div style="text-align: center; color: #64748b; padding: 20px;">Loading users...</div>
            </div>
        </div>

        <!-- Center Panel - Chat -->
        <div class="chat-panel">
            <div class="chat-header">
                <h3><i class="fas fa-comments"></i> Chat</h3>
            </div>
            <div class="chat-messages" id="messages"></div>
            <div class="message-input-area">
                <input type="text" class="message-input" id="messageInput" placeholder="Type a message..." onkeypress="if(event.key==='Enter') sendMessage()">
                <button class="send-btn" onclick="sendMessage()">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>

        <!-- Right Panel - Settings -->
        <div class="settings-panel">
            <div class="panel-title">
                <i class="fas fa-cog"></i> Media Settings
            </div>
            <div class="setting-group">
                <div class="setting-label">
                    <i class="fas fa-camera"></i> Camera
                </div>
                <select class="username-input" id="cameraSelect" disabled>
                    <option>Camera not available</option>
                </select>
            </div>
            <div class="setting-group">
                <div class="setting-label">
                    <i class="fas fa-microphone"></i> Microphone
                </div>
                <select class="username-input" id="microphoneSelect" disabled>
                    <option>Microphone not available</option>
                </select>
            </div>
            <div class="join-section">
                <div class="setting-label">
                    <i class="fas fa-user"></i> Your Name
                </div>
                <input type="text" class="username-input" id="username" value="Trader" placeholder="Enter name">
                <button class="join-btn" onclick="joinChat()">
                    <i class="fas fa-sign-in-alt"></i> Join Chat
                </button>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="arabic-footer">الحمد لله</div>
        <div style="display: flex; justify-content: center; gap: 30px; margin: 20px 0;">
            <a href="/dashboard" style="color: #64748b; text-decoration: none;">Dashboard</a>
            <a href="/finance-tools" style="color: #64748b; text-decoration: none;">All Tools</a>
            <a href="/resources" style="color: #64748b; text-decoration: none;">Resources</a>
        </div>
        <p>© 2026 Fatimah Financial Hub. All calculators are for educational purposes.</p>
        <p style="margin-top: 10px; color: #fbbf24;">Shariah-Compliant • FRED API • Real-Time Data</p>
    </footer>

    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script>
        const socket = io();
        let username = 'Trader';
        let registered = false;
        let myUserId = null;
        let myUserName = '';
        
        console.log('🔌 Connecting to socket server...');
        
        socket.on('connect', () => {
            console.log('✅ Socket connected:', socket.id);
        });
        
        function joinChat() {
            username = document.getElementById('username').value.trim() || 'Trader';
            console.log('📝 Registering as:', username);
            
            socket.emit('register-user', { username });
            addMessage('system', `Attempting to join as ${username}...`);
        }
        
        socket.on('user-registered', (data) => {
            console.log('✅ Registration confirmed:', data);
            if (data && data.success) {
                registered = true;
                myUserId = data.user?.id;
                myUserName = data.user?.username || username;
                addMessage('system', `✅ Successfully registered as ${myUserName}`);
                document.getElementById('username').disabled = true;
            }
        });
        
        socket.on('online-users', (users) => {
            console.log('👥 Online users:', users);
            document.getElementById('userCount').textContent = users.length;
            
            const userList = document.getElementById('userList');
            if (users.length === 0) {
                userList.innerHTML = '<div style="text-align: center; color: #64748b; padding: 20px;">No other users online</div>';
                return;
            }
            
            let html = '';
            users.forEach(user => {
                if (user.id !== myUserId) {
                    html += `
                        <li class="user-item">
                            <div class="user-avatar">${user.username?.charAt(0).toUpperCase() || 'U'}</div>
                            <div class="user-info">
                                <div class="user-name">${user.username}</div>
                                <div class="user-status"><span class="status-dot"></span> Online</div>
                            </div>
                        </li>
                    `;
                }
            });
            userList.innerHTML = html || '<div style="text-align: center; color: #64748b; padding: 20px;">No other users online</div>';
        });
        
        socket.on('new-message', (data) => {
            console.log('💬 Message from', data.username, ':', data.message);
            if (data.userId !== myUserId) {
                addMessage('other', `${data.username}: ${data.message}`);
            }
        });
        
        socket.on('user-joined', (user) => {
            console.log('➕ User joined:', user);
            addMessage('system', `${user.username} joined`);
        });
        
        socket.on('user-left', (user) => {
            console.log('➖ User left:', user);
            addMessage('system', `${user.username} left`);
        });
        
        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            if (!message) return;
            
            if (!registered) {
                addMessage('system', 'Please join chat first');
                return;
            }
            
            console.log('📤 Sending message:', message);
            socket.emit('send-message', { message, type: 'chat' });
            addMessage('self', `You: ${message}`);
            input.value = '';
        }
        
        function addMessage(type, text) {
            const messages = document.getElementById('messages');
            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${type}`;
            msgDiv.textContent = text;
            messages.appendChild(msgDiv);
            messages.scrollTop = messages.scrollHeight;
        }
    </script>
</body>
</html>
