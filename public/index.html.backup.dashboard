<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fatimah Financial Hub • Trading & Education Platform</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <style>
        /* === MODERN FINANCIAL THEME === */
        :root {
            --primary: #667eea;
            --secondary: #764ba2;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --dark: #1f2937;
            --light: #f9fafb;
            --card-bg: rgba(255, 255, 255, 0.95);
            --gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            color: var(--dark);
        }

        /* === NAVBAR === */
        .navbar {
            background: var(--gradient);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            color: white;
            font-size: 1.5rem;
            font-weight: bold;
        }

        .logo i {
            font-size: 1.8rem;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            align-items: center;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 20px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links a:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .user-section {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        /* === MAIN LAYOUT === */
        .container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 2rem;
            display: grid;
            gap: 2rem;
            grid-template-columns: 1fr 350px;
        }

        /* === CARDS === */
        .card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid rgba(102, 126, 234, 0.1);
        }

        .card-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* === DASHBOARD GRID === */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--gradient);
            color: white;
            padding: 1.5rem;
            border-radius: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: bold;
            margin: 10px 0;
        }

        .stat-change {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.9rem;
            opacity: 0.9;
        }

        .positive { color: var(--success); }
        .negative { color: var(--danger); }

        /* === CHARTS === */
        .chart-container {
            height: 300px;
            position: relative;
            margin: 1rem 0;
        }

        /* === TRADING SECTION === */
        .trading-panel {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            margin-top: 2rem;
        }

        .trade-form {
            display: grid;
            gap: 1rem;
            margin-top: 1rem;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        input, select, button {
            padding: 12px 16px;
            border-radius: 10px;
            border: 2px solid #e5e7eb;
            font-size: 1rem;
            transition: all 0.3s;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .btn {
            background: var(--gradient);
            color: white;
            border: none;
            cursor: pointer;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-buy { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .btn-sell { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }

        /* === ONLINE TRADERS === */
        .online-traders {
            max-height: 400px;
            overflow-y: auto;
        }

        .trader-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            margin: 8px 0;
            background: rgba(102, 126, 234, 0.05);
            border-radius: 10px;
            border-left: 4px solid var(--primary);
        }

        .trader-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .trader-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--gradient);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }

        /* === CHAT === */
        .chat-container {
            margin-top: 2rem;
            max-height: 300px;
            display: flex;
            flex-direction: column;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            background: rgba(102, 126, 234, 0.03);
            border-radius: 10px;
            margin-bottom: 1rem;
        }

        .message {
            padding: 10px 15px;
            margin: 8px 0;
            border-radius: 15px;
            max-width: 80%;
        }

        .message.self {
            background: var(--gradient);
            color: white;
            margin-left: auto;
        }

        .message.other {
            background: #e5e7eb;
            margin-right: auto;
        }

        /* === RESPONSIVE === */
        @media (max-width: 1024px) {
            .container {
                grid-template-columns: 1fr;
            }
            
            .nav-links {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="logo">
            <i class="fas fa-chart-line"></i>
            <span>Fatimah Financial Hub</span>
        </div>
        <div class="nav-links">
            <a href="/"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/trading"><i class="fas fa-exchange-alt"></i> Trading</a>
            <a href="/finance-tools"><i class="fas fa-calculator"></i> Tools</a>
            <a href="/telephony"><i class="fas fa-phone-alt"></i> Telephony</a>
            <a href="/economics"><i class="fas fa-graduation-cap"></i> Economics</a>
        </div>
        <div class="user-section">
            <div id="userStatus" class="user-status">
                <button onclick="showLoginModal()" class="btn" style="padding: 8px 20px;">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>
            </div>
        </div>
    </nav>

    <!-- MAIN DASHBOARD -->
    <div class="container">
        <div class="main-content">
            <!-- STATS CARDS -->
            <div class="dashboard-grid">
                <div class="stat-card">
                    <div>
                        <div style="opacity: 0.9;">Portfolio Value</div>
                        <div class="stat-value" id="portfolioValue">$100,000.00</div>
                        <div class="stat-change">
                            <i class="fas fa-arrow-up"></i>
                            <span class="positive">+2.34%</span> Today
                        </div>
                    </div>
                    <i class="fas fa-wallet" style="font-size: 3rem; opacity: 0.8;"></i>
                </div>

                <div class="card">
                    <div>
                        <div style="opacity: 0.9;">Virtual Cash</div>
                        <div class="stat-value" id="virtualCash">$85,430.50</div>
                        <div>Available for trading</div>
                    </div>
                </div>

                <div class="card">
                    <div>
                        <div style="opacity: 0.9;">Today's P&L</div>
                        <div class="stat-value positive" id="dailyPL">+$2,340.50</div>
                        <div class="stat-change">
                            <i class="fas fa-chart-line"></i>
                            <span>Performance</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MARKET CHART -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-chart-bar"></i>
                        Market Overview
                    </h2>
                    <select id="timeframe" onchange="updateChart()">
                        <option>1D</option>
                        <option>1W</option>
                        <option selected>1M</option>
                        <option>3M</option>
                        <option>1Y</option>
                    </select>
                </div>
                <div class="chart-container">
                    <canvas id="marketChart"></canvas>
                </div>
            </div>

            <!-- TRADING PANEL -->
            <div class="trading-panel card">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-trade-federation"></i>
                        Quick Trade
                    </h2>
                    <span id="connectionStatus" class="positive">
                        <i class="fas fa-circle" style="font-size: 0.8rem;"></i>
                        Connected
                    </span>
                </div>
                <div class="trade-form">
                    <div class="input-group">
                        <label for="symbol">Symbol</label>
                        <select id="symbol">
                            <option>AAPL</option>
                            <option>MSFT</option>
                            <option>GOOGL</option>
                            <option>AMZN</option>
                            <option>TSLA</option>
                            <option>NVDA</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label for="quantity">Quantity</label>
                        <input type="number" id="quantity" value="10" min="1">
                    </div>
                    <div class="input-group">
                        <label>Action</label>
                        <div style="display: flex; gap: 10px;">
                            <button class="btn btn-buy" onclick="placeTrade('BUY')" style="flex: 1;">
                                <i class="fas fa-arrow-up"></i> BUY
                            </button>
                            <button class="btn btn-sell" onclick="placeTrade('SELL')" style="flex: 1;">
                                <i class="fas fa-arrow-down"></i> SELL
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- LIVE TRADES FEED -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-bolt"></i>
                        Live Trades
                    </h2>
                    <span id="tradeCount">0 trades</span>
                </div>
                <div id="tradesFeed" style="max-height: 300px; overflow-y: auto;">
                    <!-- Trades will appear here -->
                </div>
            </div>
        </div>

        <!-- SIDEBAR -->
        <div class="sidebar">
            <!-- ONLINE TRADERS -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-users"></i>
                        Online Traders
                    </h2>
                    <span id="onlineCount">0</span>
                </div>
                <div id="onlineTraders" class="online-traders">
                    <!-- Traders will appear here -->
                </div>
            </div>

            <!-- CHAT -->
            <div class="card chat-container">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-comments"></i>
                        Trading Chat
                    </h2>
                </div>
                <div id="chatMessages" class="chat-messages">
                    <!-- Messages will appear here -->
                </div>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="chatInput" placeholder="Type message..." style="flex: 1;">
                    <button onclick="sendMessage()" class="btn">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>

            <!-- MARKET INDICES -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-globe"></i>
                        Market Indices
                    </h2>
                </div>
                <div id="marketIndices">
                    <!-- Indices will appear here -->
                </div>
            </div>
        </div>
    </div>

    <!-- LOGIN MODAL -->
    <div id="loginModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center;">
        <div class="card" style="width: 400px; max-width: 90%;">
            <h2 style="margin-bottom: 1rem;">Join Financial Hub</h2>
            <div class="input-group">
                <label for="username">Choose Username</label>
                <input type="text" id="username" placeholder="trader123">
            </div>
            <div style="margin-top: 1.5rem; display: flex; gap: 10px;">
                <button onclick="registerUser()" class="btn" style="flex: 1;">
                    <i class="fas fa-user-plus"></i> Join Platform
                </button>
                <button onclick="hideLoginModal()" style="flex: 1; background: #e5e7eb; color: #374151;">
                    Cancel
                </button>
            </div>
            <p style="margin-top: 1rem; font-size: 0.9rem; opacity: 0.7; text-align: center;">
                No password required for demo. Start with $100,000 virtual cash!
            </p>
        </div>
    </div>

    <script>
        // ========== GLOBAL VARIABLES ==========
        let socket = null;
        let currentUser = null;
        let marketChart = null;

        // ========== INITIALIZATION ==========
        window.onload = function() {
            connectWebSocket();
            initializeCharts();
            loadMarketData();
            simulateLiveData();
        };

        // ========== WEBSOCKET CONNECTION ==========
        function connectWebSocket() {
            socket = io();
            
            socket.on('connect', () => {
                updateConnectionStatus(true);
                console.log('Connected to trading server');
            });

            socket.on('disconnect', () => {
                updateConnectionStatus(false);
            });

            // User registration response
            socket.on('user-registered', (data) => {
                if (data.success) {
                    currentUser = data.user;
                    updateUserUI();
                    hideLoginModal();
                    showNotification('Welcome to Financial Hub!', 'success');
                }
            });

            // Online users update
            socket.on('online-users', (users) => {
                updateOnlineTraders(users);
            });

            socket.on('user-joined', (user) => {
                showNotification(`${user.username} joined the platform`, 'info');
                addOnlineTrader(user);
            });

            socket.on('user-left', (user) => {
                showNotification(`${user.username} left the platform`, 'info');
                removeOnlineTrader(user.userId);
            });

            // Live trades
            socket.on('trade-executed', (data) => {
                addTradeToFeed(data.trade, data.userId);
            });

            // Chat messages
            socket.on('new-message', (message) => {
                addChatMessage(message, false);
            });
        }

        // ========== USER MANAGEMENT ==========
        function showLoginModal() {
            document.getElementById('loginModal').style.display = 'flex';
        }

        function hideLoginModal() {
            document.getElementById('loginModal').style.display = 'none';
        }

        function registerUser() {
            const username = document.getElementById('username').value.trim();
            if (!username) {
                showNotification('Please enter a username', 'error');
                return;
            }
            
            socket.emit('register-user', { username });
        }

        function updateUserUI() {
            if (currentUser) {
                document.getElementById('userStatus').innerHTML = `
                    <div style="display: flex; align-items: center; gap: 10px; color: white;">
                        <div style="background: white; color: var(--primary); width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                            ${currentUser.username.charAt(0).toUpperCase()}
                        </div>
                        <div>
                            <div style="font-weight: bold;">${currentUser.username}</div>
                            <div style="font-size: 0.8rem; opacity: 0.8;">Portfolio: $${currentUser.portfolioValue.toLocaleString()}</div>
                        </div>
                    </div>
                `;
                
                document.getElementById('portfolioValue').textContent = `$${currentUser.portfolioValue.toLocaleString()}`;
                document.getElementById('virtualCash').textContent = `$${currentUser.virtualCash.toLocaleString()}`;
            }
        }

        // ========== TRADING FUNCTIONS ==========
        function placeTrade(action) {
            if (!currentUser) {
                showNotification('Please sign in first', 'error');
                return;
            }
            
            const symbol = document.getElementById('symbol').value;
            const quantity = parseInt(document.getElementById('quantity').value);
            
            if (!quantity || quantity <= 0) {
                showNotification('Please enter valid quantity', 'error');
                return;
            }
            
            // Simulate price
            const price = getCurrentPrice(symbol);
            const total = quantity * price;
            
            if (action === 'BUY' && total > currentUser.virtualCash) {
                showNotification('Insufficient virtual cash', 'error');
                return;
            }
            
            const tradeData = {
                userId: currentUser.id,
                symbol,
                action,
                quantity,
                price
            };
            
            socket.emit('place-trade', tradeData);
            
            // Update UI immediately
            if (action === 'BUY') {
                currentUser.virtualCash -= total;
            } else {
                currentUser.virtualCash += total;
            }
            
            currentUser.portfolioValue += (action === 'BUY' ? total : -total);
            updateUserUI();
            
            // Add to feed locally
            const trade = {
                tradeId: `TRADE_${Date.now()}`,
                symbol,
                action,
                quantity,
                price,
                totalValue: total,
                timestamp: new Date()
            };
            addTradeToFeed(trade, currentUser.id);
            
            showNotification(`${action} order placed for ${quantity} ${symbol}`, 'success');
        }

        function getCurrentPrice(symbol) {
            const prices = {
                'AAPL': 192.53,
                'MSFT': 374.58,
                'GOOGL': 138.45,
                'AMZN': 154.67,
                'TSLA': 237.49,
                'NVDA': 488.90
            };
            return prices[symbol] || 100;
        }

        // ========== CHAT FUNCTIONS ==========
        function sendMessage() {
            if (!currentUser) {
                showNotification('Please sign in first', 'error');
                return;
            }
            
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            
            if (!message) return;
            
            socket.emit('send-message', {
                message,
                type: 'chat'
            });
            
            addChatMessage({
                userId: currentUser.id,
                username: currentUser.username,
                message,
                timestamp: new Date()
            }, true);
            
            input.value = '';
        }

        function addChatMessage(message, isSelf) {
            const chatDiv = document.getElementById('chatMessages');
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${isSelf ? 'self' : 'other'}`;
            
            const time = new Date(message.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            messageDiv.innerHTML = `
                <div style="font-weight: bold; margin-bottom: 5px;">
                    ${isSelf ? 'You' : message.username}
                    <span style="font-size: 0.8rem; opacity: 0.7; margin-left: 10px;">${time}</span>
                </div>
                <div>${message.message}</div>
            `;
            
            chatDiv.appendChild(messageDiv);
            chatDiv.scrollTop = chatDiv.scrollHeight;
        }

        // ========== UI UPDATE FUNCTIONS ==========
        function updateConnectionStatus(connected) {
            const status = document.getElementById('connectionStatus');
            if (connected) {
                status.innerHTML = '<i class="fas fa-circle" style="font-size: 0.8rem; color: #10b981;"></i> Connected';
                status.className = 'positive';
            } else {
                status.innerHTML = '<i class="fas fa-circle" style="font-size: 0.8rem; color: #ef4444;"></i> Disconnected';
                status.className = 'negative';
            }
        }

        function updateOnlineTraders(users) {
            const container = document.getElementById('onlineTraders');
            const count = document.getElementById('onlineCount');
            
            container.innerHTML = '';
            users.forEach(user => addOnlineTrader(user));
            count.textContent = users.length + 1; // +1 for current user
        }

        function addOnlineTrader(user) {
            const container = document.getElementById('onlineTraders');
            const traderDiv = document.createElement('div');
            traderDiv.className = 'trader-item';
            traderDiv.id = `trader-${user.userId}`;
            
            traderDiv.innerHTML = `
                <div class="trader-info">
                    <div class="trader-avatar">
                        ${user.username.charAt(0).toUpperCase()}
                    </div>
                    <div>
                        <div style="font-weight: bold;">${user.username}</div>
                        <div style="font-size: 0.9rem; opacity: 0.7;">
                            $${user.portfolioValue.toLocaleString()}
                        </div>
                    </div>
                </div>
                <div class="positive" style="font-size: 0.8rem;">
                    <i class="fas fa-circle" style="font-size: 0.6rem;"></i>
                    Online
                </div>
            `;
            
            container.appendChild(traderDiv);
        }

        function removeOnlineTrader(userId) {
            const element = document.getElementById(`trader-${userId}`);
            if (element) element.remove();
            
            const count = document.getElementById('onlineCount');
            const current = parseInt(count.textContent) || 0;
            if (current > 0) count.textContent = current - 1;
        }

        function addTradeToFeed(trade, userId) {
            const feed = document.getElementById('tradesFeed');
            const tradeDiv = document.createElement('div');
            
            const time = new Date(trade.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            const isBuy = trade.action === 'BUY';
            
            tradeDiv.className = 'trader-item';
            tradeDiv.innerHTML = `
                <div style="display: flex; justify-content: space-between; width: 100%;">
                    <div>
                        <div style="font-weight: bold; color: ${isBuy ? '#10b981' : '#ef4444'}">
                            ${trade.action} ${trade.symbol}
                        </div>
                        <div style="font-size: 0.9rem; opacity: 0.7;">
                            ${trade.quantity} shares @ $${trade.price.toFixed(2)}
                        </div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-weight: bold;">$${(trade.quantity * trade.price).toLocaleString()}</div>
                        <div style="font-size: 0.8rem; opacity: 0.7;">${time}</div>
                    </div>
                </div>
            `;
            
            feed.insertBefore(tradeDiv, feed.firstChild);
            
            // Update trade count
            const count = document.getElementById('tradeCount');
            const current = parseInt(count.textContent) || 0;
            count.textContent = `${current + 1} trades`;
            
            // Keep only last 10 trades
            if (feed.children.length > 10) {
                feed.removeChild(feed.lastChild);
            }
        }

        // ========== CHART FUNCTIONS ==========
        function initializeCharts() {
            const ctx = document.getElementById('marketChart').getContext('2d');
            
            marketChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
                    datasets: [{
                        label: 'Portfolio Value',
                        data: [95000, 97000, 98000, 102000, 105000, 103000, 107000],
                        borderColor: '#667eea',
                        backgroundColor: 'rgba(102, 126, 234, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: {
                                callback: function(value) {
                                    return '$' + value.toLocaleString();
                                }
                            }
                        },
                        x: {
                            grid: { color: 'rgba(0,0,0,0.05)' }
                        }
                    }
                }
            });
        }

        function updateChart() {
            // In real app, fetch new data based on timeframe
            const timeframe = document.getElementById('timeframe').value;
            console.log('Updating chart for:', timeframe);
        }

        // ========== MARKET DATA ==========
        function loadMarketData() {
            fetch('/api/market-data')
                .then(response => response.json())
                .then(data => {
                    displayMarketIndices(data.indices);
                })
                .catch(error => {
                    console.error('Error loading market data:', error);
                    // Fallback data
                    displayMarketIndices([
                        { symbol: '^GSPC', name: 'S&P 500', price: 4780.45, change: 12.34, changePercent: 0.26 },
                        { symbol: '^DJI', name: 'Dow Jones', price: 37592.98, change: 45.67, changePercent: 0.12 },
                        { symbol: '^IXIC', name: 'NASDAQ', price: 14972.76, change: 78.90, changePercent: 0.53 }
                    ]);
                });
        }

        function displayMarketIndices(indices) {
            const container = document.getElementById('marketIndices');
            container.innerHTML = '';
            
            indices.forEach(index => {
                const isPositive = index.change >= 0;
                const indexDiv = document.createElement('div');
                indexDiv.className = 'trader-item';
                indexDiv.innerHTML = `
                    <div>
                        <div style="font-weight: bold;">${index.symbol}</div>
                        <div style="font-size: 0.9rem; opacity: 0.7;">${index.name}</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-weight: bold;">${index.price.toFixed(2)}</div>
                        <div style="color: ${isPositive ? '#10b981' : '#ef4444'}; font-size: 0.9rem;">
                            ${isPositive ? '+' : ''}${index.change.toFixed(2)} (${isPositive ? '+' : ''}${index.changePercent.toFixed(2)}%)
                        </div>
                    </div>
                `;
                container.appendChild(indexDiv);
            });
        }

        // ========== SIMULATION & UTILITIES ==========
        function simulateLiveData() {
            // Simulate portfolio value changes
            setInterval(() => {
                if (currentUser && Math.random() > 0.3) {
                    const change = (Math.random() - 0.5) * 500;
                    currentUser.portfolioValue += change;
                    
                    const plElement = document.getElementById('dailyPL');
                    if (change >= 0) {
                        plElement.textContent = `+$${change.toFixed(2)}`;
                        plElement.className = 'stat-value positive';
                    } else {
                        plElement.textContent = `-$${Math.abs(change).toFixed(2)}`;
                        plElement.className = 'stat-value negative';
                    }
                    
                    document.getElementById('portfolioValue').textContent = 
                        `$${currentUser.portfolioValue.toLocaleString()}`;
                }
            }, 5000);
            
            // Simulate other traders joining
            setInterval(() => {
                if (Math.random() > 0.7 && currentUser) {
                    const fakeTraders = ['QuantumTrader', 'AlgoMaster', 'ChartWizard', 'FinanceGuru'];
                    const randomTrader = fakeTraders[Math.floor(Math.random() * fakeTraders.length)];
                    
                    socket.emit('user-joined', {
                        userId: `fake_${Date.now()}`,
                        username: randomTrader,
                        portfolioValue: 50000 + Math.random() * 150000,
                        timestamp: new Date()
                    });
                }
            }, 10000);
        }

        function showNotification(message, type = 'info') {
            // Create notification element
            const notification = document.createElement('div');
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: ${type === 'error' ? '#ef4444' : type === 'success' ? '#10b981' : '#3b82f6'};
                color: white;
                padding: 15px 20px;
                border-radius: 10px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
                z-index: 10000;
                animation: slideIn 0.3s ease;
                max-width: 300px;
            `;
            
            notification.innerHTML = `
                <div style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-${type === 'error' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i>
                    <div>${message}</div>
                </div>
            `;
            
            document.body.appendChild(notification);
            
            // Remove after 3 seconds
            setTimeout(() => {
                notification.style.animation = 'slideOut 0.3s ease';
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        // Add animation styles
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideIn {
                from { transform: translateX(100%); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
            @keyframes slideOut {
                from { transform: translateX(0); opacity: 1; }
                to { transform: translateX(100%); opacity: 0; }
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
