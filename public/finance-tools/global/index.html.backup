<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Financial Calculators</title>
    <link rel="stylesheet" href="../shared/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1><i class="fas fa-globe-americas"></i> Global Financial Calculators</h1>
            <p>Country-specific financial planning with real-world rates</p>
        </div>
        
        <!-- Country Selector -->
        <div class="country-selector">
            <div id="country-container">
                <p>Select your country to see local rates:</p>
                <!-- Country selector will be added here by JavaScript -->
            </div>
        </div>
        
        <!-- Calculators Grid -->
        <div class="calculator-grid">
            <!-- Mortgage Calculator -->
            <div id="mortgage-calculator">
                <!-- Mortgage UI will be loaded here -->
            </div>
            
            <!-- Live Rate Display -->
            <div id="live-rates-container" style="display: none; margin-bottom: 20px;">
                <div class="calculator-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <h3><i class="fas fa-bolt"></i> Live Market Rates</h3>
                    <div id="live-rates-content">
                        <p>Loading current rates...</p>
                    </div>
                    <button id="refresh-rates" style="margin-top: 10px; padding: 8px 15px; background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); border-radius: 4px; cursor: pointer;">
                        <i class="fas fa-sync-alt"></i> Refresh Rates
                    </button>
                    <p style="font-size: 0.8em; opacity: 0.8; margin-top: 5px;">
                        <i class="fas fa-info-circle"></i> US rates update automatically
                    </p>
                </div>
            </div>

            <!-- Investment Calculator -->
            <div class="calculator-card">
                <h3><i class="fas fa-chart-line"></i> Investment Calculator</h3>
                <div class="current-rate">
                    Current <span class="country-name">US</span> return: 
                    <span class="investment-rate">7.00%</span>
                </div>
                <div id="investment-inputs">
                    <div class="input-group">
                        <label for="investment-amount">Initial Investment</label>
                        <input type="number" id="investment-amount" class="form-input" value="10000">
                    </div>
                    <div class="input-group">
                        <label for="investment-monthly">Monthly Contribution</label>
                        <input type="number" id="investment-monthly" class="form-input" value="500">
                    </div>
                    <div class="input-group">
                        <label for="investment-years">Years to Invest</label>
                        <input type="number" id="investment-years" class="form-input" value="20">
                    </div>
                    <div class="input-group">
                        <label for="investment-rate">Expected Return (%)</label>
                        <input type="number" id="investment-rate" class="form-input" placeholder="Leave empty for country default">
                        <div class="input-hint">Leave empty to use country default rate</div>
                    </div>
                </div>
                <button id="calculate-investment" class="calculate-btn">
                    Calculate Investment <i class="fas fa-rocket"></i>
                </button>
                <div id="investment-results" class="results">
                    Enter values and click calculate
                </div>
            </div>
            
            <!-- Retirement Calculator -->
            <div class="calculator-card">
                <h3><i class="fas fa-umbrella-beach"></i> Retirement Planner</h3>
                <div class="current-rate">
                    <span class="country-name">US</span> average return: 
                    <span class="retirement-rate">7.00%</span>
                </div>
                <div id="retirement-inputs">
                    <div class="input-group">
                        <label for="retirement-age">Current Age</label>
                        <input type="number" id="retirement-age" class="form-input" value="35">
                    </div>
                    <div class="input-group">
                        <label for="retirement-target">Retirement Age</label>
                        <input type="number" id="retirement-target" class="form-input" value="65">
                    </div>
                    <div class="input-group">
                        <label for="retirement-savings">Current Savings</label>
                        <input type="number" id="retirement-savings" class="form-input" value="50000">
                    </div>
                    <div class="input-group">
                        <label for="retirement-monthly">Monthly Savings</label>
                        <input type="number" id="retirement-monthly" class="form-input" value="1000">
                    </div>
                    <div class="input-group">
                        <label for="retirement-rate">Expected Return (%)</label>
                        <input type="number" id="retirement-rate" class="form-input" placeholder="Leave empty for country default">
                        <div class="input-hint">Leave empty to use country default rate</div>
                    </div> 
                </div>
                <button id="calculate-retirement" class="calculate-btn">
                    Plan Retirement <i class="fas fa-calendar-alt"></i>
                </button>
                <div id="retirement-results" class="results">
                    Enter your retirement goals
                </div>
            </div>
            
            <!-- Loan Payoff Calculator -->
            <div class="calculator-card">
                <h3><i class="fas fa-hand-holding-usd"></i> Loan Payoff</h3>
                <div id="loan-inputs">
                    <div class="input-group">
                        <label for="loan-amount">Loan Amount</label>
                        <input type="number" id="loan-amount" class="form-input" value="25000">
                    </div>
                    <div class="input-group">
                        <label for="loan-rate">Interest Rate (%)</label>
                        <input type="number" id="loan-rate" class="form-input" value="7.5">
                    </div>
                    <div class="input-group">
                        <label for="loan-payment">Minimum Payment</label>
                        <input type="number" id="loan-payment" class="form-input" value="300">
                    </div>
                    <div class="input-group">
                        <label for="loan-extra">Extra Monthly Payment</label>
                        <input type="number" id="loan-extra" class="form-input" value="100">
                    </div>
                </div>
                <button id="calculate-loan" class="calculate-btn">
                    Calculate Payoff <i class="fas fa-calendar-check"></i>
                </button>
                <div id="loan-results" class="results">
                    See how extra payments save time & money
                </div>
            </div>
        </div>

        
        <!-- Global Tools Navigation -->
        <div style="margin-top: 40px; padding-top: 20px; border-top: 1px solid #eee;">
            <h3 style="color: #4a6fa5; margin-bottom: 15px;">
                <i class="fas fa-globe-americas"></i> Additional Global Tools
            </h3>
            <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                <a href="currency-converter.html" class="calculator-card" 
                   style="flex: 1; min-width: 200px; text-align: center; padding: 20px;">
                    <h3><i class="fas fa-exchange-alt"></i> Currency Converter</h3>
                    <p>Convert between currencies with custom rates</p>
                </a>
                <a href="index.html" class="calculator-card"
                   style="flex: 1; min-width: 200px; text-align: center; padding: 20px;">
                    <h3><i class="fas fa-calculator"></i> Financial Calculators</h3>
                    <p>Mortgage, investment, retirement, loan payoff</p>
                </a>
            </div>
        </div>
        
        <!-- Footer -->
        <div class="footer" style="text-align: center; padding: 20px; color: #6c757d; border-top: 1px solid #dee2e6;">
            <p>Rates updated Q1 2024. Calculations are estimates. Consult a financial advisor for personalized advice.</p>
        </div>
    </div>

    <!-- JavaScript Files -->
    <script src="../shared/api-keys.js"></script>
    <script src="../shared/real-time-rates.js"></script>
    <script src="../shared/config.js"></script>
    <script src="../shared/calculators.js"></script>
    <script src="../modules/ui-controls.js"></script>
    <script src="../modules/mortgage-ui.js"></script>    

    
    <!-- Main Application Script -->
    <script>
        // ========== LIVE RATES FUNCTIONS ==========
        
        // Live Rates Feature
        async function initializeLiveRates() {
            const liveRatesContainer = document.getElementById('live-rates-container');
            const liveRatesContent = document.getElementById('live-rates-content');
            const refreshBtn = document.getElementById('refresh-rates');
            
            if (!liveRatesContainer || !window.RealTimeRates) {
                console.log('Live rates not available');
                return;
            }
            
            // Show the container
            liveRatesContainer.style.display = 'block';
            
            // Load initial rates
            await updateLiveRatesDisplay();
            
            // Setup refresh button
            refreshBtn.addEventListener('click', async function() {
                refreshBtn.disabled = true;
                refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
                
                // Force refresh by clearing cache
                if (window.RealTimeRates) {
                    window.RealTimeRates.clearCache();
                }
                
                await updateLiveRatesDisplay();
                
                setTimeout(() => {
                    refreshBtn.disabled = false;
                    refreshBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Refresh Rates';
                }, 1000);
            });
            
            // Update rates when country changes to US
            const originalUpdateAllCalculators = window.updateAllCalculators;
            window.updateAllCalculators = function(countryCode) {
                // Call original function
                if (originalUpdateAllCalculators) {
                    originalUpdateAllCalculators(countryCode);
                }
                
                // Update live rates display if US is selected
                if (countryCode === 'US') {
                    updateLiveRatesDisplay();
                }
            };
        }
        
        async function updateLiveRatesDisplay() {
            const liveRatesContent = document.getElementById('live-rates-content');
            if (!liveRatesContent) return;
            
            liveRatesContent.innerHTML = '<p><i class="fas fa-spinner fa-spin"></i> Fetching current rates...</p>';
            
            try {
                // Get current country
                const country = window.FinancialConfig?.userSettings?.country || 'US';
                
                if (country === 'US') {
                    // Fetch US live rates
                    const rates = await window.RealTimeRates.fetchUSRates();
                    
                    liveRatesContent.innerHTML = `
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <div>
                                <strong>Mortgage Rate:</strong><br>
                                <span style="font-size: 1.2em;">${rates.mortgage30yr}%</span>
                            </div>
                            <div>
                                <strong>Fed Funds Rate:</strong><br>
                                <span style="font-size: 1.2em;">${rates.fedFundsRate}%</span>
                            </div>
                            <div>
                                <strong>Inflation:</strong><br>
                                <span style="font-size: 1.2em;">${rates.inflationRate}%</span>
                            </div>
                            <div>
                                <strong>Investment Return:</strong><br>
                                <span style="font-size: 1.2em;">${rates.investmentReturn}%</span>
                            </div>
                        </div>
                        <p style="font-size: 0.8em; margin-top: 10px; opacity: 0.8;">
                            <i class="fas fa-clock"></i> Updated: ${new Date(rates.lastUpdated).toLocaleTimeString()}
                            ${rates.isLiveData ? '<br><i class="fas fa-check-circle"></i> Live market data' : '<br><i class="fas fa-exclamation-triangle"></i> Using cached data'}
                        </p>
                    `;
                } else {
                    // For non-US countries, show static rates
                    const mortgageRate = await window.FinancialConfig.getRate('mortgage30yr', country);
                    const investmentReturn = await window.FinancialConfig.getRate('retirementReturn', country);
                    
                    liveRatesContent.innerHTML = `
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <div>
                                <strong>Mortgage Rate:</strong><br>
                                <span style="font-size: 1.2em;">${mortgageRate}%</span>
                            </div>
                            <div>
                                <strong>Investment Return:</strong><br>
                                <span style="font-size: 1.2em;">${investmentReturn}%</span>
                            </div>
                        </div>
                        <p style="font-size: 0.8em; margin-top: 10px; opacity: 0.8;">
                            <i class="fas fa-database"></i> Static rates (Q1 2024)
                            <br><i class="fas fa-info-circle"></i> Live rates available for US only
                        </p>
                    `;
                }
                
            } catch (error) {
                console.error('Error updating live rates:', error);
                liveRatesContent.innerHTML = `
                    <p style="color: #ff6b6b;">
                        <i class="fas fa-exclamation-triangle"></i> Could not load live rates
                    </p>
                    <p style="font-size: 0.8em;">Error: ${error.message}</p>
                `;
            }
        } 


        // ========== MAIN APPLICATION ==========        

        // Wait for DOM to load
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM loaded, initializing app...');

            // DEBUG: Check if FinancialCalculators is loaded correctly
            console.log('FinancialCalculators type:', typeof window.FinancialCalculators);
            console.log('Is constructor?', typeof window.FinancialCalculators === 'function');
            console.log('FinancialCalculators:', window.FinancialCalculators);  
            
            // Initialize UI Controls
            if (window.UIControls) {
                const ui = new UIControls();
                
                // Create country selector
                ui.createCountrySelector('country-container', function(countryCode) {
                    // Update all calculators when country changes
                    updateAllCalculators(countryCode);
                });
                
                // Initialize mortgage calculator
                console.log('MortgageUI available?', !!window.MortgageUI);
                console.log('Mortgage container:', document.getElementById('mortgage-calculator'));
                if (window.MortgageUI) {
                    const mortgageUI = new MortgageUI();
                    mortgageUI.initialize('mortgage-calculator');
                }
                
                // After initializing mortgage
                setTimeout(function() {
                    const mortgageDiv = document.getElementById('mortgage-calculator');
                    console.log('Mortgage div innerHTML length:', mortgageDiv.innerHTML.length);
                    console.log('Mortgage div content:', mortgageDiv.innerHTML.substring(0, 100) + '...');
                }, 1000);


                // Initialize live rates
                setTimeout(() => {
                    initializeLiveRates();
                }, 1500);


                // Setup other calculators
                setupInvestmentCalculator();
                setupRetirementCalculator();
                setupLoanCalculator();
                
            } else {
                console.error('UIControls not loaded');
                document.getElementById('country-container').innerHTML = 
                    '<div class="error">Error loading UI controls. Check console.</div>';
            }
        });
        
        // Update all calculators when country changes
        function updateAllCalculators(countryCode) {
            console.log('Country changed to:', countryCode);

            // Define ui if it exists
            let ui;
            if (window.UIControls) {
                ui = new UIControls();
                ui.updateCountryDisplay(countryCode);
            }
            
            
            // Update mortgage calculator if available
            if (window.MortgageUI) {
                const mortgageUI = new MortgageUI();
                mortgageUI.onCountryChange(countryCode);
            }
        }
        
        // Investment Calculator
        function setupInvestmentCalculator() {
            document.getElementById('calculate-investment').addEventListener('click', function() {
                const amount = parseFloat(document.getElementById('investment-amount').value) || 0;
                const monthly = parseFloat(document.getElementById('investment-monthly').value) || 0;
                const years = parseFloat(document.getElementById('investment-years').value) || 20;
                const rate = parseFloat(document.getElementById('investment-rate').value) || null;
                const country = window.FinancialConfig?.userSettings?.country || 'US';
                
                const resultsDiv = document.getElementById('investment-results');
                resultsDiv.innerHTML = '<div class="loading">Calculating...</div>';
                
                setTimeout(function() {
                    if (window.FinancialCalculators) {
                        const calc = new FinancialCalculators();
                        const result = calc.calculateInvestment({
                            initial: amount,
                            monthly: monthly,
                            years: years,  
                            rate: rate,     
                            country: country
                        });
                        
                        if (result.success) {
                            resultsDiv.innerHTML = `
                                <div class="success">
                                    <h4>Investment Projection</h4>
                                    <div class="result-item">
                                        <strong>Future Value:</strong> ${result.future}
                                    </div>
                                    <div class="result-item">
                                        <strong>Total Invested:</strong> ${result.totalInvested || 'N/A'}
                                    </div>
                                    <div class="result-item">
                                        <strong>Annual Return:</strong> ${result.returnRate}
                                    </div>
                                </div>
                            `;
                        } else {
                            resultsDiv.innerHTML = `<div class="error">Error: ${result.error}</div>`;
                        }
                    } else {
                        resultsDiv.innerHTML = '<div class="error">Calculators not available</div>';
                    }
                }, 300);
            });
        }
        
        // Retirement Calculator
        function setupRetirementCalculator() {
            document.getElementById('calculate-retirement').addEventListener('click', function() {
                const currentAge = parseFloat(document.getElementById('retirement-age').value) || 35;
                const retirementAge = parseFloat(document.getElementById('retirement-target').value) || 65;
                const currentSavings = parseFloat(document.getElementById('retirement-savings').value) || 0;
                const monthlySave = parseFloat(document.getElementById('retirement-monthly').value) || 0;
                const country = window.FinancialConfig?.userSettings?.country || 'US';
                const rate = parseFloat(document.getElementById('retirement-rate').value) || null;
                
                const resultsDiv = document.getElementById('retirement-results');
                resultsDiv.innerHTML = '<div class="loading">Calculating...</div>';
                
                setTimeout(function() {
                    if (window.FinancialCalculators) {
                        const calc = new FinancialCalculators();
                        const result = calc.calculateRetirement({
                            currentAge: currentAge,
                            retirementAge: retirementAge,
                            currentSavings: currentSavings,
                            monthlySave: monthlySave,
                            rate: rate,
                            country: country
                        });
                        
                        if (result.success) {
                            resultsDiv.innerHTML = `
                                <div class="success">
                                    <h4>Retirement Readiness</h4>
                                    <div class="result-item">
                                        <strong>Savings at Retirement:</strong> ${result.savingsAtRetirement}
                                    </div>
                                    <div class="result-item">
                                        <strong>Safe Withdrawal:</strong> ${result.safeWithdrawal}
                                    </div>
                                    <div class="result-item">
                                        <strong>Years Covered:</strong> ${result.yearsCovered}
                                    </div>
                                    <div class="result-item">
                                        <strong>Readiness:</strong> ${result.readiness}
                                    </div>
                                </div>
                            `;
                        } else {
                            resultsDiv.innerHTML = `<div class="error">Error: ${result.error}</div>`;
                        }
                    } else {
                        resultsDiv.innerHTML = '<div class="error">Calculators not available</div>';
                    }
                }, 300);
            });
        }
        
        // Loan Calculator
        function setupLoanCalculator() {
            document.getElementById('calculate-loan').addEventListener('click', function() {
                const amount = parseFloat(document.getElementById('loan-amount').value) || 0;
                const rate = parseFloat(document.getElementById('loan-rate').value) || 0;
                const minPayment = parseFloat(document.getElementById('loan-payment').value) || 0;
                const extraPayment = parseFloat(document.getElementById('loan-extra').value) || 0;
                const country = window.FinancialConfig?.userSettings?.country || 'US';
                
                const resultsDiv = document.getElementById('loan-results');
                resultsDiv.innerHTML = '<div class="loading">Calculating...</div>';
                
                setTimeout(function() {
                    if (window.FinancialCalculators) {
                        const calc = new FinancialCalculators();
                        const result = calc.calculateLoanPayoff({
                            amount: amount,
                            rate: rate,
                            minPayment: minPayment,
                            extraPayment: extraPayment,
                            country: country
                        });
                        
                        if (result.success) {
                            resultsDiv.innerHTML = `
                                <div class="success">
                                    <h4>Loan Payoff Analysis</h4>
                                    <div class="result-section">
                                        <h5>With Minimum Payments:</h5>
                                        <div class="result-item">
                                            <span>Time:</span> <span>${result.withMinimum.years} years</span>
                                        </div>
                                        <div class="result-item">
                                            <span>Total Interest:</span> <span>${result.withMinimum.totalInterest}</span>
                                        </div>
                                    </div>
                                    <div class="result-section">
                                        <h5>With Extra Payments:</h5>
                                        <div class="result-item">
                                            <span>Time:</span> <span>${result.withExtra.years} years</span>
                                        </div>
                                        <div class="result-item">
                                            <span>Total Interest:</span> <span>${result.withExtra.totalInterest}</span>
                                        </div>
                                        <div class="result-item highlight">
                                            <span>You Save:</span> <span>${result.withExtra.timeSaved} and ${result.withExtra.interestSaved}</span>
                                        </div>
                                    </div>
                                </div>
                            `;
                        } else {
                            resultsDiv.innerHTML = `<div class="error">Error: ${result.error}</div>`;
                        }
                    } else {
                        resultsDiv.innerHTML = '<div class="error">Calculators not available</div>';
                    }
                }, 300);
            });
        }
    </script>
</body>
</html>
